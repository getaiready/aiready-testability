{
  "name": "@aiready/contract-enforcement",
  "version": "0.2.5",
  "description": "Measures structural type safety and boundary validation to reduce fallback cascades for AI agents",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && pnpm publish --no-git-checks"
  },
  "keywords": [
    "aiready",
    "contract-enforcement",
    "type-safety",
    "static-analysis",
    "ai-ready",
    "typescript",
    "structural-contracts",
    "defensive-coding",
    "error-handling"
  ],
  "author": "AIReady Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caopengau/aiready-contract-enforcement.git"
  },
  "homepage": "https://github.com/caopengau/aiready-contract-enforcement",
  "dependencies": {
    "@aiready/core": "workspace:*",
    "@typescript-eslint/typescript-estree": "^8.53.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
